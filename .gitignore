# Ansible vault password files - NEVER COMMIT THESE!
*.pass
*.vault
vault.pass
.vault_pass
password.txt
.secret

# Ignore vault password files in any project directory
*/vault.pass
*/*/vault.pass

# Log files in any project
*terminal_log.txt
*termonal_log.txt
*.log
*/terminal_log.txt
*/termonal_log.txt

# Python cache files
__pycache__/
*.pyc

# Ansible retry files
*.retry

# IDE files
.vscode/
.idea/

# OS files
.DS_Store
Thumbs.db

# SSH keys (if any accidentally copied)
*.pem
*.ppk

